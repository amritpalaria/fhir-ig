         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/codeableconcept-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/codeableconcept-314e" ]
       ] ;
       fhir:name [ fhir:v "314e CodeableConcept" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR CodeableConcept datatype.\n\nThis profile supports:\n- standard terminology codings\n- optional customer-specific internal codings\n\nInternal codings are used to preserve customer, EHR,\nworkflow, and source-system-native semantic classifications and source system fidelity.\n\nAny coding system intended to represent an internal coding\nsystem SHALL follow the required naming convention:\n\n[customer]-[ehr]-[ResourceType]-[resource-subtype]-[element]-[SourceSpecificString]-InternalCode\n\nExample:\nacme-epic-Observation-lab-code-Glucose-InternalCode" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/coding-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/coding-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Coding" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR Coding datatype.\n\nThis profile strengthens semantic interoperability expectations\naround population of system, code, and display.\n\nWhen display is populated, code SHALL also be populated.\n\nIf source data lacks a formal coded value but provides textual\ndisplay content, implementers SHOULD generate a surrogate code\nusing the display text transformed as follows:\n- convert all letters to lower case\n- replace spaces with hyphens\n\nExample:\nDisplay: \"Blood Culture\"\nGenerated code: \"blood-culture\"\n\nWhenever either code or display is populated, system SHALL\nalso be populated.\n\nThis data type supports:\n- standard terminology codings\n- optional customer-specific internal codings\nInternal codings are used to preserve customer, EHR,\nworkflow, and source-system-native semantic classifications and source system fidelity.\n\nAny coding system intended to represent an internal coding\nsystem SHALL follow the required naming convention:\n\n[customer]-[ehr]-[ResourceType]-[resource-subtype]-[element]-[SourceSpecificString]-InternalCode\n\nExample:\nacme-epic-Observation-lab-code-Glucose-InternalCode" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/datetime-accuracy-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/datetime-accuracy-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Date/Time Accuracy" ] ;
       fhir:description [ fhir:v "Specifies the accuracy or exactness of a dateTime value when only some part of \nthe known/ usable precision of dateTime can be verified as accurate or exact and the rest is estimated or approximate.\n\nThis extension is intended to explicitly communicate the accuracy\nof a dateTime value, such as full timestamp, year-only, year-month, date-only, or\nnone.\n\nFor example:\n- A birth year and month may be known exactly but the day might be an estimate\n- Only the date may be verifiable as accurate with the time being approximate\n\nNote: All dateTime values in the 314e implementation guide SHALL be stored in UTC." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/datetime-precision-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/datetime-precision-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Date/Time Precision" ] ;
       fhir:description [ fhir:v "Specifies the meaningful/ usable precision of a dateTime value when the \ndatatype syntactically permits greater precision than is actually known or clinically usable.\n\nThis extension is intended to explicitly communicate the usable precision\nof a dateTime value, such as year-only, year-month, date-only, or\nfull timestamp precision.\n\nAll dateTime values in the 314e implementation guide SHALL be stored in UTC." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:primitive-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/datetime-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/datetime-314e" ]
       ] ;
       fhir:name [ fhir:v "314e dateTime" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR dateTime primitive datatype.\n\nAll dateTime values SHALL be stored in UTC.\n\nIf only a smaller degree of precision is usable\n(for example, only the date portion is known),\nthe following extension SHALL be used:\n\nhttp://314e.com/fhir/StructureDefinition/datetime-precision-314e\n\nIf all or part of the usable date/time value is approximate rather than exact,\nthe following extension SHALL be used:\n\nhttps://hl7.org.au/fhir/StructureDefinition/date-accuracy-indicator" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:primitive-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/decimal-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/decimal-314e" ]
       ] ;
       fhir:name [ fhir:v "314e decimal" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR decimal primitive datatype.\n\nSupports explicit precision representation using:\n\nhttp://hl7.org/fhir/StructureDefinition/quantity-precision\n\nThis extension specifies the intended or known precision\nof the decimal value independently of the actual lexical form." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/duration-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/duration-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Duration" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR Duration datatype.\n\nDerived from FHIR Duration and incorporates\n314e Quantity datatype behavior including:\n\n- quantity precision support\n- quantity string support\n- value string support" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/observation-lab-general-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/observation-lab-general-314e" ]
       ] ;
       fhir:name [ fhir:v "314e General Laboratory Observation" ] ;
       fhir:description [ fhir:v "314e profile for general laboratory observations.\n\nThis profile derives from the QI Core Laboratory Result Observation profile\nand constrains datatypes to corresponding 314e datatype profiles where applicable.\n\nA required category slice SHALL identify the laboratory subcategory\nusing a code from LabCategorySubcategory314eVS.\n\nThis profile also supports the ValueAttachment314e extension\nfor scenarios where the laboratory result cannot be represented\nusing structured Observation.value[x] datatypes or plain text." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/identifier-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/identifier-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Identifier" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR Identifier datatype.\n\nThis profile requires Identifier.system whenever\nIdentifier.value is populated.\n\nFor customer-specific or internally defined identifiers,\nIdentifier.system SHALL follow the naming convention:\n\n[customer]-[ehr]-[ResourceType]-[resource-subtype]-[eleMent]-[SourceSpecificString]-InternalIdentifier\n\nExample:\nacme-cerner-Observation-lab-identifier-AccessionNumber-InternalIdentifier" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:primitive-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/instant-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/instant-314e" ]
       ] ;
       fhir:name [ fhir:v "314e instant" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR instant primitive datatype.\n\nAll instant values SHALL be stored in UTC.\n\nAn instant represents an exact point in time and therefore\ndoes not support approximate or estimated accuracy semantics.\n\nIf only a smaller degree of precision is usable\n(for example, only minute precision is meaningful),\nthe following extension SHALL be used:\n\nhttp://314e.com/fhir/StructureDefinition/datetime-precision-314e" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/lab-category-subcategory-314e> ;
         fhir:reference [ fhir:v "ValueSet/lab-category-subcategory-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Lab Subcategories" ] ;
       fhir:description [ fhir:v "Procedure subcategories of Lab category used for more granular\noperational classification." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/observation-microbiology-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/observation-microbiology-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Microbiology Observation" ] ;
       fhir:description [ fhir:v "314e profile for microbiology laboratory observations." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/observation-microorganism-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/observation-microorganism-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Microorganism Observation" ] ;
       fhir:description [ fhir:v "314e profile for microorganism observations." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/value-attachment-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/value-attachment-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Observation Value Attachment" ] ;
       fhir:description [ fhir:v "Extension used when an Observation result cannot be represented\nusing one of the standard structured Observation.value[x]\ndatatypes or as plain text.\n\nTypical use cases include:\n- PDF laboratory reports\n- proprietary binary result payloads\n- waveform files\n- image-based interpretations\n- externally generated rendered documents\n- rich formatted diagnostic content\n\nThe attachment represents the clinically relevant result payload." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/period-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/period-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Period" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR Period datatype.\n\nAll dateTime values within the Period SHALL conform\nto the 314e DateTime profile requirements,\nincluding UTC normalization and precision handling." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/CodeSystem/procedure-category-314e> ;
         fhir:reference [ fhir:v "CodeSystem/procedure-category-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Procedure Category CodeSystem" ] ;
       fhir:description [ fhir:v "Hierarchical procedure categories used for operational,\nworkflow, and semantic classification of Procedure resources." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/procedure-category-subcategory-314e> ;
         fhir:reference [ fhir:v "ValueSet/procedure-category-subcategory-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Procedure Subcategories" ] ;
       fhir:description [ fhir:v "Procedure subcategories used for more granular\noperational classification." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/quantity-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/quantity-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Quantity" ] ;
       fhir:description [ fhir:v "An extended Quantity datatype supporting precision metadata and alternate textual representations.\n\nThis profile SHALL be used so that the data can be faithfully represented in the following scenarios:<br/>\n1. The quantity value, such as a vital sign reading or a lab result value, is limited to a defined number of digits \nafter the decimal in the source and this precision needs to be recorded with the value.<br/>\n2. The display-oriented or source-oriented textual representation of a quantity needs to be recorded, either in addition \nto the computable elements or because the original representation cannot be separated into distinct value and unit.<br/>\n3. The original source representation of a quantity value needs to be preserved, either because the original \nrepresentation of value cannot be converted to numeric or for display or audit purposes." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/range-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/range-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Range" ] ;
       fhir:description [ fhir:v "A 314e-constrained Range datatype using 314e\nSimpleQuantity profiles." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/ratio-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/ratio-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Ratio" ] ;
       fhir:description [ fhir:v "A 314e-constrained Ratio datatype using 314e Quantity profiles." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/reference-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/reference-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Reference" ] ;
       fhir:description [ fhir:v "A constrained Reference datatype profile supporting semantic\nqualification of references using the reference-context extension.\n\nThis profile enables references to carry additional information\nabout the role, capacity, purpose, or contextual meaning of\nthe referenced resource." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/sampleddata-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/sampleddata-314e" ]
       ] ;
       fhir:name [ fhir:v "314e SampledData" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR SampledData datatype.\n\nThis profile constrains numeric and quantity-related\nelements to corresponding 314e datatype profiles.\n\nSampledData is typically used for:\n- waveforms\n- physiological telemetry\n- ECG traces\n- continuous monitoring streams\n- device-generated measurements" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/servicerequest-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/servicerequest-314e" ]
       ] ;
       fhir:name [ fhir:v "314e ServiceRequest" ] ;
       fhir:description [ fhir:v "A 314e-constrained ServiceRequest profile derived from\nQI-Core ServiceRequest.\n\nThis profile requires classification of the requested service\nusing standardized high-level service categories and uses\n314e datatype profiles where applicable." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/simplequantity-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/simplequantity-314e" ]
       ] ;
       fhir:name [ fhir:v "314e SimpleQuantity" ] ;
       fhir:description [ fhir:v "A 314e-constrained SimpleQuantity datatype supporting\nprecision metadata and alternate textual representations." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:primitive-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/time-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/time-314e" ]
       ] ;
       fhir:name [ fhir:v "314e time" ] ;
       fhir:description [ fhir:v "314e profile of the FHIR time primitive datatype - a time during the day, \nin the format hh:mm:ss. There is no date specified. \nSeconds must be provided due to schema type constraints but may be zero-filled \nand may be ignored at receiver discretion. The time \"24:00\" SHALL NOT be used. \nA time zone SHALL NOT be present. Times can be converted to a Duration since midnight.\n\nIf only a smaller degree of precision than syntactically recorded is usable\n(for example, only hour and minute are known),\nthe following extension SHALL be used:\n\nhttp://314e.com/fhir/StructureDefinition/time-precision-314e\n\nIf all or part of the usable time value is approximate rather than exact,\nthe following extension SHALL be used:\n\nhttp://314e.com/fhir/StructureDefinition/time-accuracy-indicator-314e" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/time-accuracy-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/time-accuracy-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Time Accuracy" ] ;
       fhir:description [ fhir:v "Specifies the accuracy or exactness of a time value when only some part of \nthe known/ usable precision of time can be verified as accurate or exact and the rest is estimated or approximate.\n\nThis extension is intended to explicitly communicate the accuracy\nof a time value." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/time-accuracy-units-vs> ;
         fhir:reference [ fhir:v "ValueSet/time-accuracy-units-vs" ]
       ] ;
       fhir:name [ fhir:v "314e Time Exactness Units ValueSet" ] ;
       fhir:description [ fhir:v "Allowed exactness/ accurate precision units for dateTime, time, and instant precision indicators." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/time-precision-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/time-precision-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Time Precision" ] ;
       fhir:description [ fhir:v "Specifies the meaningful/ usable precision of a time value when the \ndatatype syntactically permits greater precision than is actually known or clinically usable.\n\nThis extension is intended to explicitly communicate the usable precision\nof a time value." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/CodeSystem/time-precision-units-cs> ;
         fhir:reference [ fhir:v "CodeSystem/time-precision-units-cs" ]
       ] ;
       fhir:name [ fhir:v "314e Time Precision Units" ] ;
       fhir:description [ fhir:v "Time precision units used to indicate the actual precision of a dateTime, time, or instant value." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/time-precision-units-vs> ;
         fhir:reference [ fhir:v "ValueSet/time-precision-units-vs" ]
       ] ;
       fhir:name [ fhir:v "314e Time Precision Units ValueSet" ] ;
       fhir:description [ fhir:v "Allowed precision units for dateTime, time, and instant precision indicators." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/timing-314e> ;
         fhir:reference [ fhir:v "StructureDefinition/timing-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Timing" ] ;
       fhir:description [ fhir:v "Describes the occurrence of an event that may occur multiple times. Timing schedules are used \nfor specifying when events are expected or requested to occur and may also be used to represent \nthe summary of a past or ongoing event. For simplicity, the definitions of Timing components \nare expressed as 'future' events, but such components can also be used to describe historic or ongoing events.\n\nA Timing schedule can be a list of events and/or criteria for when the event happens, which can \nbe expressed in a structured form and/or as a code. When both event and a repeating specification \nare provided, the list of events should be understood as an interpretation of the information in the repeat structure.\n\nNote: The Timing data type allows modifier extensions.\n\n314e profile of the FHIR Timing datatype uses 314e datatype profiles \nincluding DateTime314e, Period314e, CodeableConcept314e and Quantity314e." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/annotation-attachment> ;
         fhir:reference [ fhir:v "StructureDefinition/annotation-attachment" ]
       ] ;
       fhir:name [ fhir:v "Annotation Attachment" ] ;
       fhir:description [ fhir:v "Provides an attachment-based representation of annotation or note\ncontent when the annotation is not represented as inline plain text.\n\nThis extension supports scenarios in which annotation content is\nstored externally as an attachment rather than directly populated\nwithin Annotation.text." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/antimicrobial-susceptibility-testing-vs> ;
         fhir:reference [ fhir:v "ValueSet/antimicrobial-susceptibility-testing-vs" ]
       ] ;
       fhir:name [ fhir:v "Antimicrobial Susceptibility Testing" ] ;
       fhir:description [ fhir:v "Observation methods for antimicrobial susceptibility testing.\nIncludes HL7 v3 ObservationMethod code 0280 and all descendant codes." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/attachment-helperFile> ;
         fhir:reference [ fhir:v "StructureDefinition/attachment-helperFile" ]
       ] ;
       fhir:name [ fhir:v "Attachment Helper File" ] ;
       fhir:description [ fhir:v "Provides the path or filename of a helper/supporting file associated\nwith an Attachment.\n\nThis extension is intended for scenarios in which the consumer of\nthe attachment requires an auxiliary/helper file in order to correctly\ninterpret, process, transform, or render the attachment content.\n\nExamples include:\n- XSLT files associated with XML documents\n- Schema files\n- Rendering templates\n- Transformation scripts\n- Supporting metadata files" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/attachment-tag> ;
         fhir:reference [ fhir:v "StructureDefinition/attachment-tag" ]
       ] ;
       fhir:name [ fhir:v "Attachment Tag" ] ;
       fhir:description [ fhir:v "A categorization or semantic tag associated with an Attachment.\n\nThis extension allows multiple tags to be associated with an\nAttachment for workflow, classification, indexing, retrieval,\nprocessing, or application behavior purposes." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/CodeSystem/attachment-tag-cs> ;
         fhir:reference [ fhir:v "CodeSystem/attachment-tag-cs" ]
       ] ;
       fhir:name [ fhir:v "Attachment Tag CodeSystem" ] ;
       fhir:description [ fhir:v "Codes used for semantic tagging and categorization of attachments." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/attachment-tag> ;
         fhir:reference [ fhir:v "ValueSet/attachment-tag" ]
       ] ;
       fhir:name [ fhir:v "Attachment Tag ValueSet" ] ;
       fhir:description [ fhir:v "Standard semantic tags used for categorization and workflow\nqualification of attachments." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/microorganism-by-method-vs> ;
         fhir:reference [ fhir:v "ValueSet/microorganism-by-method-vs" ]
       ] ;
       fhir:name [ fhir:v "Microorganism by Method" ] ;
       fhir:description [ fhir:v "LOINC methods used to identify microorganisms." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/CodeSystem/observation-tag> ;
         fhir:reference [ fhir:v "CodeSystem/observation-tag" ]
       ] ;
       fhir:name [ fhir:v "Observation Tag CodeSystem" ] ;
       fhir:description [ fhir:v "Codes used to qualify DiagnosticReport and Observation resources\nwithin hierarchical parent-child result/report structures." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/ValueSet/observation-tag-vs> ;
         fhir:reference [ fhir:v "ValueSet/observation-tag-vs" ]
       ] ;
       fhir:name [ fhir:v "Observation Tag ValueSet" ] ;
       fhir:description [ fhir:v "Semantic tags used in meta.tag to qualify DiagnosticReport and\nObservation resources participating in hierarchical parent-child\nresource structures." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/quantity-quantityString> ;
         fhir:reference [ fhir:v "StructureDefinition/quantity-quantityString" ]
       ] ;
       fhir:name [ fhir:v "Quantity Quantity String" ] ;
       fhir:description [ fhir:v "A string representation of Quantity. \n\nThis extension preserves the original lexical representation of a quantity. \nAdditionally, in scenarios where FHIR requires Quantity datatype but the source data \ncannot be represented as distinct value and unit, this extension \nSHALL be utilized.\n\nThis extension is intended for preservation of textual rendering and does not replace \nthe computable Quantity elements.\n\nApplications should preserve synchronization between the computable Quantity content\nand this extension if either representation is modified." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/quantity-valueString> ;
         fhir:reference [ fhir:v "StructureDefinition/quantity-valueString" ]
       ] ;
       fhir:name [ fhir:v "Quantity Value String" ] ;
       fhir:description [ fhir:v "A string/ textual representation associated with Quantity.value.\n\nIn scenarios where the ‘value’ of Quantity datatype cannot be expressed as a numerical value \neven though a distinct unit can be represented in the ‘unit’ element, this \nextension SHALL be used on the value field of Quantity.\n\nThe presence of this extension does not alter the numeric semantics\nof Quantity.value. \n\nApplications performing calculations SHALL use the actual decimal\nvalue of Quantity.value rather than the string carried in this extension.\n\nApplications should preserve synchronization between Quantity.value\nand this extension if either representation is modified." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://314e.com/fhir/ig/StructureDefinition/reference-context> ;
         fhir:reference [ fhir:v "StructureDefinition/reference-context" ]
       ] ;
       fhir:name [ fhir:v "Reference Context" ] ;
       fhir:description [ fhir:v "Provides additional semantic context describing the role,\ncapacity, purpose, or functional meaning of a Reference.\n\nThis extension is intended for use in situations where the\nbase FHIR element is broadly defined and the precise meaning\nor role of the referenced resource requires further clarification.\n\nFor example, the performer element of an Observation may\nreference practitioners participating in different capacities\nsuch as technician, phlebotomist, or pathologist." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] ) ;
