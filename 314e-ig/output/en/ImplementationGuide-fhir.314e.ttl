         fhir:reference [ fhir:v "ValueSet/procedure-category-broad-314e" ]
       ] ;
       fhir:name [ fhir:v "314e Broad Procedure Categories" ] ;
       fhir:description [ fhir:v "Top-level operational categories for procedures\nand service requests." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
