       fhir:value [ fhir:v "input/operations" ]
     ] [
       fhir:code [ fhir:v "path-resource" ] ;
       fhir:value [ fhir:v "input/profiles" ]
     ] [
       fhir:code [ fhir:v "path-resource" ] ;
       fhir:value [ fhir:v "input/resources" ]
     ] [
       fhir:code [ fhir:v "path-resource" ] ;
       fhir:value [ fhir:v "input/vocabulary" ]
     ] [
       fhir:code [ fhir:v "path-resource" ] ;
