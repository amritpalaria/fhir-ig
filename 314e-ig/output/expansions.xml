                  </span>
                </td>
                <td>
                  <span class="copy-text-inline">
                    <button data-clipboard-text="&lt;coding&gt;&lt;system value=&quot;http://314e.com/fhir/CodeSystem/attachment-tag&quot;&gt;&lt;version value=&quot;1.0.0&quot;&gt;&lt;code value=&quot;inline-data-externalized-to-file&quot;&gt;&lt;display value=&quot;Inline data externalized to and saved as file&quot;&gt;&lt;/coding&gt;" title="Click to Copy as Coding" class="btn-copy"> </button>
                  </span>
                </td>
              </tr>
              <tr>
                <td>
                  <a name="x-http://314e.com/fhir/CodeSystem/attachment-tag-duplicate"> </a>
