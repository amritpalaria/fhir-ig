                    <button data-clipboard-text="{&quot;system&quot;: &quot;http://314e.com/fhir/CodeSystem/attachment-tag&quot;, &quot;version&quot;: &quot;1.0.0&quot;, &quot;code&quot;: &quot;duplicate&quot;, &quot;display&quot;: &quot;Duplicate of another attachment on the same element&quot;}" title="Click to Copy as Coding" class="btn-copy"> </button>
