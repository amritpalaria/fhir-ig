@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://314e.com/fhir/ig/CodeSystem/attachment-tag> a fhir:CodeSystem ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "attachment-tag"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: CodeSystem attachment-tag</b></p><a name=\"attachment-tag\"> </a><a name=\"hcattachment-tag\"> </a><p>This case-sensitive code system <code>http://314e.com/fhir/CodeSystem/attachment-tag</code> defines the following codes:</p><table class=\"codes\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td style=\"white-space:nowrap\">inline-data-externalized-to-file<a name=\"attachment-tag-inline-data-externalized-to-file\"> </a></td><td>Inline data externalized and saved as file</td><td><div><p>Indicates that the Attachment content was originally available\nas inline data/blob content but has been externalized and saved\nas a file in object storage, with the Attachment.url carrying\nthe storage location.</p>\n<p>If this tag is absent, the content SHALL be assumed to have\noriginated as an external file rather than inline data.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\">duplicate<a name=\"attachment-tag-duplicate\"> </a></td><td>Duplicate of another attachment on the same element</td><td><div><p>Indicates that this attachment was created as a duplicate of the\ncontent in another attachment on the same element for some reason,\nfor example because the same content needed to be stored as two\ndifferent content types.</p>\n</div></td></tr><tr><td style=\"white-space:nowrap\">hidden<a name=\"attachment-tag-hidden\"> </a></td><td>Hidden from application use</td><td><div><p>Indicates to the consumer application that this attachment should\nnot be used even though it exists in the data.</p>\n<p>This may be used to identify the preferred/usable attachment when\nmultiple copies of equivalent content are available.</p>\n</div></td></tr></table></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:url [
     fhir:v "http://314e.com/fhir/CodeSystem/attachment-tag"^^xsd:anyURI ;
     fhir:l <http://314e.com/fhir/CodeSystem/attachment-tag>
  ] ; # 
  fhir:version [ fhir:v "1.0.0"] ; # 
  fhir:name [ fhir:v "AttachmentTagCS"] ; # 
  fhir:title [ fhir:v "Attachment Tag CodeSystem"] ; # 
  fhir:status [ fhir:v "active"] ; # 
  fhir:date [ fhir:v "2026-05-16T13:10:22+05:30"^^xsd:dateTime] ; # 
  fhir:publisher [ fhir:v "314e"] ; # 
  fhir:contact ( [
     fhir:name [ fhir:v "314e" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "http://314e.com" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "Codes used for semantic tagging and categorization of attachments."] ; # 
  fhir:caseSensitive [ fhir:v true] ; # 
  fhir:content [ fhir:v "complete"] ; # 
  fhir:count [ fhir:v "3"^^xsd:nonNegativeInteger] ; # 
  fhir:concept ( [
     fhir:code [ fhir:v "inline-data-externalized-to-file" ] ;
     fhir:display [ fhir:v "Inline data externalized and saved as file" ] ;
     fhir:definition [ fhir:v "Indicates that the Attachment content was originally available\nas inline data/blob content but has been externalized and saved\nas a file in object storage, with the Attachment.url carrying\nthe storage location.\n\nIf this tag is absent, the content SHALL be assumed to have\noriginated as an external file rather than inline data." ]
  ] [
     fhir:code [ fhir:v "duplicate" ] ;
     fhir:display [ fhir:v "Duplicate of another attachment on the same element" ] ;
     fhir:definition [ fhir:v "Indicates that this attachment was created as a duplicate of the\ncontent in another attachment on the same element for some reason,\nfor example because the same content needed to be stored as two\ndifferent content types." ]
  ] [
     fhir:code [ fhir:v "hidden" ] ;
     fhir:display [ fhir:v "Hidden from application use" ] ;
     fhir:definition [ fhir:v "Indicates to the consumer application that this attachment should\nnot be used even though it exists in the data.\n\nThis may be used to identify the preferred/usable attachment when\nmultiple copies of equivalent content are available." ]
  ] ) . # 

