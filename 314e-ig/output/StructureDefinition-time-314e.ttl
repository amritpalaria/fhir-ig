       fhir:short [ fhir:v "Indicates the precision that is verified as clinically exact or accurate" ] ;
       fhir:definition [ fhir:v "Specifies the accuracy or exactness of a time value when only some part of \nthe known/usable precision of time can be verified as accurate or exact and the rest is estimated or approximate.\n\nExamples include:\n- hour precision\n- minute precision\n- second precision\n- millisecond precision\n- none" ] ;
